def _render_index(history: History) -> str:
    baseline = (
        history.baseline_sha[:SHORT_SHA_LEN]
        if history.baseline_sha
        else "unset"
    )
    attempts = history.attempts
    if not attempts:
        body = '<div class="empty">No attempts yet.</div>'
    else:
        rows_html = []
        for a in attempts:
            delta = a.get("delta_time_pct")
            if delta is None:
                delta_str = "—"
                delta_cls = ""
            else:
                delta_str = f"{delta:+.2f}%"
                delta_cls = "delta-neg" if delta < 0 else "delta-pos"
            status = a.get("status", "")
            rows_html.append(
                f"<tr>"
                f"<td class='id'>#{a['id']}</td>"
                f"<td><span class='status status-{html.escape(status)}'>{html.escape(status)}</span></td>"
                f"<td class='delta {delta_cls}'>{delta_str}</td>"
                f"<td>{html.escape(a.get('description', ''))}</td>"
                f"</tr>"
            )
        body = (
            "<table>"
            "<thead><tr>"
            "<th>#</th><th>Status</th><th>Δ time</th><th>Description</th>"
            "</tr></thead>"
            f"<tbody>{''.join(rows_html)}</tbody>"
            "</table>"
        )
    return INDEX_TEMPLATE.format(
        baseline=html.escape(baseline),
        n_attempts=len(attempts),
        body=body,
    )


def _make_app(config: Config) -> Any:
    from fastapi import FastAPI
    from fastapi.responses import HTMLResponse

    app = FastAPI(title="bfoptimize")

    @app.get("/", response_class=HTMLResponse)
    def index() -> str:
        return _render_index(History(config.cache_dir))

    @app.get("/api/history")
    def api_history() -> dict[str, Any]:
        h = History(config.cache_dir)
        return {"baseline_sha": h.baseline_sha, "attempts": h.attempts}

    return app


def serve(config: Config) -> int:
    try:
        import uvicorn
    except ImportError as e:
        print(
            f"error: {e}\n"
            f"install dependencies with: "
            f"pip install -r tools/bfoptimize.requirements.txt",
            file=sys.stderr,
        )
        return 1

    app = _make_app(config)
    print(
        f"bfoptimize serving on http://0.0.0.0:{config.port} (all interfaces)",
        file=sys.stderr,
    )
    uvicorn.run(app, host="0.0.0.0", port=config.port, log_level="warning")
    return 0


def main() -> int:
    args = _build_parser().parse_args()
    config = Config.from_args(args)
    history = History(config.cache_dir)

    if config.dry_run:
        print(f"config: {config}")
        print(f"baseline_sha: {history.baseline_sha}")
        print(f"attempts: {len(history.attempts)}")
        return 0

    if config.serve:
        return serve(config)

    return run(config, history)


if __name__ == "__main__":
    sys.exit(main())
