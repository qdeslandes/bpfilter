#!/usr/bin/env python3
"""bfoptimize — LLM-driven BPF bytecode optimization loop for bpfilter."""

from __future__ import annotations

import argparse
import asyncio
import dataclasses
import html
import json
import multiprocessing
import pathlib
import shutil
import subprocess
import sys
from typing import Any, TYPE_CHECKING

if TYPE_CHECKING:
    import anthropic
    import rich.console

DEFAULT_SOURCES = pathlib.Path(".")
DEFAULT_BUILD_DIR = pathlib.Path("build")
DEFAULT_CACHE_DIR = pathlib.Path(".cache/bfoptimize")
DEFAULT_ITERATIONS = 10
DEFAULT_MODEL = "claude-opus-4-7"
DEFAULT_EFFORT = "high"
CGEN_DIR = "src/libbpfilter/cgen"
SHORT_SHA_LEN = 7

# Map --effort to a thinking budget. Higher effort = more reasoning tokens.
EFFORT_BUDGETS = {"low": 4000, "medium": 16000, "high": 32000}


@dataclasses.dataclass
class Config:
    """Runtime knobs. Shared between CLI invocations and the web UI."""

    iterations: int = DEFAULT_ITERATIONS
    sources: pathlib.Path = dataclasses.field(
        default_factory=lambda: DEFAULT_SOURCES
    )
    build_dir: pathlib.Path = dataclasses.field(
        default_factory=lambda: DEFAULT_BUILD_DIR
    )
    cache_dir: pathlib.Path = dataclasses.field(
        default_factory=lambda: DEFAULT_CACHE_DIR
    )
    model: str = DEFAULT_MODEL
    effort: str = DEFAULT_EFFORT
    hint: str | None = None
    dry_run: bool = False
    propose_only: bool = False
    serve: bool = False
    port: int = 8080

    @classmethod
    def from_args(cls, args: argparse.Namespace) -> Config:
        return cls(
            iterations=args.iterations,
            sources=args.sources,
            build_dir=args.build_dir,
            cache_dir=args.cache_dir,
            model=args.model,
            effort=args.effort,
            hint=args.hint,
            dry_run=args.dry_run,
            propose_only=args.propose_only,
            serve=args.serve,
            port=args.port,
        )


class History:
    """Persists per-iteration attempts and the current baseline SHA."""

    def __init__(self, cache_dir: pathlib.Path) -> None:
        self._path = cache_dir / "history.json"
        self._data: dict[str, Any] = self._load()

    def _load(self) -> dict[str, Any]:
        if self._path.exists():
            return json.loads(self._path.read_text())
        return {"baseline_sha": None, "attempts": []}

    def save(self) -> None:
        self._path.parent.mkdir(parents=True, exist_ok=True)
        self._path.write_text(json.dumps(self._data, indent=2))

    @property
    def baseline_sha(self) -> str | None:
        return self._data.get("baseline_sha")

    @baseline_sha.setter
    def baseline_sha(self, sha: str | None) -> None:
        self._data["baseline_sha"] = sha

    @property
    def attempts(self) -> list[dict[str, Any]]:
        return self._data.setdefault("attempts", [])

    def next_id(self) -> int:
        attempts = self.attempts
        return (attempts[-1]["id"] + 1) if attempts else 1

    def add_attempt(self, attempt: dict[str, Any]) -> None:
        self.attempts.append(attempt)
        self.save()


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="bfoptimize",
        description="LLM-driven BPF bytecode optimization loop for bpfilter.",
    )
    parser.add_argument(
        "--iterations",
        type=int,
        default=DEFAULT_ITERATIONS,
        help=f"number of optimization attempts to run (default: {DEFAULT_ITERATIONS}).",
    )
    parser.add_argument(
        "--sources",
        type=pathlib.Path,
        default=DEFAULT_SOURCES,
        help=f'path to the bpfilter source checkout (default: "{DEFAULT_SOURCES}").',
    )
    parser.add_argument(
        "--build-dir",
        type=pathlib.Path,
        default=DEFAULT_BUILD_DIR,
        help=f'cmake build directory (default: "{DEFAULT_BUILD_DIR}").',
    )
    parser.add_argument(
        "--cache-dir",
        type=pathlib.Path,
        default=DEFAULT_CACHE_DIR,
        help=f'state directory for history.json and intermediate artifacts (default: "{DEFAULT_CACHE_DIR}").',
    )
    parser.add_argument(
        "--model",
        type=str,
        default=DEFAULT_MODEL,
        help=f'Anthropic model id (default: "{DEFAULT_MODEL}").',
    )
    parser.add_argument(
        "--effort",
        type=str,
        default=DEFAULT_EFFORT,
        choices=["low", "medium", "high"],
        help=f'reasoning effort level (default: "{DEFAULT_EFFORT}").',
    )
    parser.add_argument(
        "--hint",
        type=str,
        default=None,
        help="optional free-text hint passed to the model for this run.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="parse arguments, load history, print state, then exit.",
    )
    parser.add_argument(
        "--propose-only",
        action="store_true",
        help="generate a proposal and save it to history without applying. Useful for inspecting model output.",
    )
    parser.add_argument(
        "--serve",
        action="store_true",
        help="expose a local web UI on --port instead of running the loop headlessly.",
    )
    parser.add_argument(
        "--port",
        type=int,
        default=8080,
        help="TCP port for --serve (default: 8080).",
    )
    return parser


def load_cgen_sources(sources_dir: pathlib.Path) -> str:
    """Concatenate every cgen .c/.h file into one annotated blob."""
    cgen_path = sources_dir / CGEN_DIR
    parts: list[str] = []
    for f in sorted(cgen_path.rglob("*.[ch]")):
        rel = f.relative_to(sources_dir)
        try:
            content = f.read_text(encoding="utf-8")
        except UnicodeDecodeError:
            continue
        parts.append(f"=== {rel} ===\n{content}")
    return "\n\n".join(parts)


def _history_summary(history: History) -> str:
    if not history.attempts:
        return "No previous attempts."
    lines = ["Previous optimization attempts (do not repeat these):"]
    for a in history.attempts:
        delta = (
            f"{a['delta_time_pct']:+.1f}%"
            if a.get("delta_time_pct") is not None
            else "N/A"
        )
        lines.append(
            f"  #{a['id']} [{a.get('status', '?')}] {a.get('description', '')} "
            f"(weighted runtime delta: {delta})"
        )
    return "\n".join(lines)


def plan_optimization(
    client: "anthropic.Anthropic",
    console: "rich.console.Console",
    config: Config,
    history: History,
) -> str:
    """Query the model for ONE concrete optimization plan; return its text."""
    cgen_sources = load_cgen_sources(config.sources)
    prompt = f"""You are optimizing the BPF bytecode generation logic in the bpfilter project.

The cgen directory generates BPF programs that run in the Linux kernel for packet filtering.
Every nanosecond saved matters — these programs execute for every packet received by the host.

## Source files in {CGEN_DIR}/

{cgen_sources}

## Optimization history

{_history_summary(history)}

## Task

Propose exactly ONE concrete optimization to the cgen code. Describe:
1. Which file(s) you will change and what specifically you will change
2. Why this will reduce the runtime of the generated BPF programs
3. Any risks or tricky edge cases to handle

Be specific and actionable. Do not repeat any previously attempted optimization.
Output only the optimization proposal — no code yet."""

    if config.hint:
        prompt += (
            f"\n\n## Hint\n\n{config.hint}\n\n"
            "This is a direction to consider, not a constraint — "
            "you may propose a different optimization if you judge it more impactful."
        )

    budget = EFFORT_BUDGETS[config.effort]
    with client.messages.stream(
        model=config.model,
        max_tokens=budget + 8000,
        thinking={"type": "enabled", "budget_tokens": budget},
        messages=[{"role": "user", "content": prompt}],
    ) as stream:
        for event in stream:
            if event.type == "content_block_delta":
                if event.delta.type == "thinking_delta":
                    console.print(event.delta.thinking, end="")
                elif event.delta.type == "text_delta":
                    console.print(event.delta.text, end="")
        console.print("")
        response = stream.get_final_message()

    return next(b.text for b in response.content if b.type == "text")


def _git_head_sha(path: pathlib.Path) -> str:
    return subprocess.run(
        ["git", "-C", str(path), "rev-parse", "HEAD"],
        check=True,
        capture_output=True,
        text=True,
    ).stdout.strip()


def _git_anchor_attempt(
    sources: pathlib.Path, attempt_id: int, sha: str
) -> None:
    """Pin a commit under refs/bfoptimize/<id> so worktree destruction
    cannot orphan it."""
    subprocess.run(
        [
            "git",
            "-C",
            str(sources),
            "update-ref",
            f"refs/bfoptimize/{attempt_id}",
            sha,
        ],
        check=True,
    )


def _weighted_delta(rows: list[Any]) -> float:
    """Mean delta_time_pct weighted by baseline runtime.

    Slower benchmarks dominate the score: a 10% regression on a 1000ns
    benchmark outweighs a 10% improvement on a 100ns one.
    """
    if not rows:
        return 0.0
    total_weight = sum(r.base_time_ns for r in rows)
    if total_weight == 0:
        return 0.0
    return sum(r.delta_time_pct * r.base_time_ns for r in rows) / total_weight


def _create_worktree(
    sources: pathlib.Path,
    baseline_sha: str,
    worktree: pathlib.Path,
) -> None:
    """Create a detached worktree at baseline_sha at the given path."""
    if worktree.exists():
        subprocess.run(
            ["git", "-C", str(sources), "worktree", "remove", "-f", str(worktree)],
            check=False,
        )
        shutil.rmtree(worktree, ignore_errors=True)
    worktree.parent.mkdir(parents=True, exist_ok=True)
    subprocess.run(
        [
            "git",
            "-C",
            str(sources),
            "worktree",
            "add",
            "--detach",
            str(worktree),
            baseline_sha,
        ],
        check=True,
    )


def _destroy_worktree(sources: pathlib.Path, worktree: pathlib.Path) -> None:
    subprocess.run(
        ["git", "-C", str(sources), "worktree", "remove", "-f", str(worktree)],
        check=False,
    )
    shutil.rmtree(worktree, ignore_errors=True)


async def execute_in_worktree(
    config: Config,
    plan: str,
    worktree: pathlib.Path,
    baseline_sha: str,
    console: "rich.console.Console",
) -> str | None:
    """Run the agent inside the worktree to apply, build and test the plan.

    Returns the new HEAD SHA if the agent committed, else None.
    """
    from claude_agent_sdk import (
        AssistantMessage,
        ClaudeAgentOptions,
        ResultMessage,
        TextBlock,
        query,
    )

    abs_wt = worktree.resolve()
    abs_build = abs_wt / "build"
    ncpus = multiprocessing.cpu_count()

    prompt = f"""You are implementing a performance optimization to the bpfilter BPF bytecode generator.

## Optimization to implement

{plan}

## Rules

- Modify ONLY files under `{abs_wt}/{CGEN_DIR}/`. Do not touch any other path.
- Build with:
    cmake -S {abs_wt} -B {abs_build} -DNO_DOCS=1 -DCMAKE_BUILD_TYPE=release
    make -C {abs_build} -j{ncpus} test_bin
- Test with:
    make -C {abs_build} -j{ncpus} test
- If both build and tests pass: commit with
    git -C {abs_wt} commit -am "lib: cgen: <one-line summary of the change>"
- If build or tests fail: diagnose and fix. If you cannot make tests pass,
  revert your changes with
    git -C {abs_wt} checkout -- {abs_wt}/{CGEN_DIR}/
  and exit without committing.
- The baseline is {baseline_sha[:SHORT_SHA_LEN]}. Only commit when tests are
  green. The orchestrator inspects HEAD after you exit."""

    async for message in query(
        prompt=prompt,
        options=ClaudeAgentOptions(
            cwd=str(abs_wt),
            permission_mode="bypassPermissions",
            allowed_tools=["Read", "Edit", "Write", "Bash", "Glob", "Grep"],
        ),
    ):
        if isinstance(message, AssistantMessage):
            for block in message.content:
                if isinstance(block, TextBlock) and block.text.strip():
                    console.log(f"[dim]{block.text.strip()[:200]}[/dim]")
        elif isinstance(message, ResultMessage) and message.result:
            console.log(f"agent done: {message.result[:200]}")

    new_sha = _git_head_sha(worktree)
    return new_sha if new_sha != baseline_sha else None


def run(config: Config, history: History) -> int:
    """Optimization loop."""
    try:
        import anthropic
        import rich.console
    except ImportError as e:
        print(
            f"error: {e}\n"
            f"install dependencies with: "
            f"pip install -r tools/bfoptimize.requirements.txt",
            file=sys.stderr,
        )
        return 1

    console = rich.console.Console(log_path=False)
    client = anthropic.Anthropic()

    if history.baseline_sha is None:
        history.baseline_sha = _git_head_sha(config.sources)
        history.save()
        console.log(
            f"baseline initialized to {history.baseline_sha[:SHORT_SHA_LEN]}"
        )

    for i in range(config.iterations):
        attempt_id = history.next_id()
        baseline = history.baseline_sha
        assert baseline is not None
        console.log(
            f"[bold]Attempt {attempt_id} ({i + 1}/{config.iterations})"
            f" — baseline {baseline[:SHORT_SHA_LEN]}[/]"
        )

        plan_text = plan_optimization(client, console, config, history)
        description = next(
            (line.strip() for line in plan_text.splitlines() if line.strip()),
            "",
        )

        attempt: dict[str, Any] = {
            "id": attempt_id,
            "status": "proposed",
            "description": description,
            "plan": plan_text,
            "baseline_sha": baseline,
            "delta_time_pct": None,
        }
        history.add_attempt(attempt)

        if config.propose_only:
            console.log(
                "[yellow]--propose-only: stopping after recording proposal[/]"
            )
            break

        worktree = config.cache_dir / "worktrees" / f"attempt-{attempt_id}"
        try:
            _create_worktree(config.sources, baseline, worktree)
            new_sha = asyncio.run(
                execute_in_worktree(config, plan_text, worktree, baseline, console)
            )
            if new_sha is None:
                attempt["status"] = "rejected_tests"
                console.log("[yellow]agent did not commit — rejecting attempt[/]")
                history.save()
                continue

            _git_anchor_attempt(config.sources, attempt_id, new_sha)
            attempt["status"] = "applied"
            attempt["worktree_sha"] = new_sha
            history.save()
            console.log(
                f"[green]agent committed {new_sha[:SHORT_SHA_LEN]}"
                f" — running benchmark gate[/]"
            )

            sys.path.insert(
                0, str((config.sources / "tests" / "benchmarks").resolve())
            )
            from bfbencher_lib import compare

            rows = compare(
                baseline,
                new_sha,
                sources=config.sources,
                cache_dir=config.cache_dir / "bfbencher",
            )
            delta = _weighted_delta(rows)
            attempt["delta_time_pct"] = delta

            if delta < 0:
                attempt["status"] = "kept"
                history.baseline_sha = new_sha
                console.log(
                    f"[bold green]kept attempt {attempt_id}: "
                    f"weighted delta = {delta:+.2f}%, advancing baseline[/]"
                )
            else:
                attempt["status"] = "rejected_benchmark"
                console.log(
                    f"[yellow]rejected: weighted delta = {delta:+.2f}% "
                    f"(no improvement)[/]"
                )
            history.save()
        finally:
            _destroy_worktree(config.sources, worktree)

    return 0


