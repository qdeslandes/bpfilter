def _render_index() -> str:
    return INDEX_TEMPLATE.format(
        baseline="",
        n_attempts="",
        body=INDEX_BODY.format(default_model=html.escape(DEFAULT_MODEL)),
    )


# RunRequest must live at module scope: FastAPI resolves the body annotation
# via typing.get_type_hints(handler), which only looks at module globals. A
# class defined inside _make_app() would not be reachable from there and
# FastAPI would silently fall back to treating `body` as a query parameter.
# The pydantic import is wrapped so --dry-run still works without the deps.
try:
    from pydantic import BaseModel as _PydanticBase

    class RunRequest(_PydanticBase):
        iterations: int = DEFAULT_ITERATIONS
        sources: str | None = None
        build_dir: str | None = None
        cache_dir: str | None = None
        model: str = DEFAULT_MODEL
        effort: str = DEFAULT_EFFORT
        hint: str | None = None
        propose_only: bool = False
except ImportError:
    RunRequest = None  # type: ignore[assignment,misc]


def _make_app(config: Config) -> Any:
    from fastapi import FastAPI, HTTPException
    from fastapi.responses import HTMLResponse, StreamingResponse

    app = FastAPI(title="bfoptimize")

    @app.get("/", response_class=HTMLResponse)
    def index() -> str:
        return _render_index()

    @app.get("/api/history")
    def api_history() -> dict[str, Any]:
        h = History(config.cache_dir)
        return {"baseline_sha": h.baseline_sha, "attempts": h.attempts}

    @app.get("/api/state")
    def api_state() -> dict[str, bool]:
        return {"running": _RUN_THREAD is not None and _RUN_THREAD.is_alive()}

    @app.post("/api/run", status_code=202)
    def api_start_run(body: RunRequest) -> dict[str, str]:
        global _RUN_THREAD
        if _RUN_THREAD is not None and _RUN_THREAD.is_alive():
            raise HTTPException(409, "already running")

        run_config = dataclasses.replace(
            config,
            iterations=body.iterations,
            sources=pathlib.Path(body.sources) if body.sources else config.sources,
            build_dir=pathlib.Path(body.build_dir)
            if body.build_dir
            else config.build_dir,
            cache_dir=pathlib.Path(body.cache_dir)
            if body.cache_dir
            else config.cache_dir,
            model=body.model,
            effort=body.effort,
            hint=body.hint,
            propose_only=body.propose_only,
        )
        history = History(run_config.cache_dir)

        _CANCEL_EVENT.clear()
        with _LOG_LOCK:
            _LOG_BUFFER.clear()

        def _thread_target() -> None:
            try:
                run(run_config, history)
            except Exception as e:
                tb = traceback.format_exc()
                print(tb, file=sys.stderr)
                _broadcast(f"[error] {type(e).__name__}: {e}")

        _RUN_THREAD = threading.Thread(target=_thread_target, daemon=True)
        _RUN_THREAD.start()
        return {"status": "started"}

    @app.delete("/api/run")
    def api_cancel_run() -> dict[str, str]:
        if _RUN_THREAD is None or not _RUN_THREAD.is_alive():
            raise HTTPException(404, "no run in progress")
        _CANCEL_EVENT.set()
        return {"status": "cancelling"}

    @app.get("/api/stream")
    async def api_stream() -> StreamingResponse:
        async def gen() -> Any:
            last_idx = 0
            while True:
                with _LOG_LOCK:
                    buf_len = len(_LOG_BUFFER)
                    new = list(_LOG_BUFFER)[last_idx:]
                    last_idx = buf_len
                for line in new:
                    yield f"data: {line}\n\n"
                await asyncio.sleep(0.5)

        return StreamingResponse(gen(), media_type="text/event-stream")

    return app


def serve(config: Config) -> int:
    try:
        import uvicorn
    except ImportError as e:
        print(
            f"error: {e}\n"
            f"install dependencies with: "
            f"pip install -r tools/bfoptimize.requirements.txt",
            file=sys.stderr,
        )
        return 1

    app = _make_app(config)
    print(
        f"bfoptimize serving on http://0.0.0.0:{config.port} (all interfaces)",
        file=sys.stderr,
    )
    # timeout_graceful_shutdown=2: the SSE /api/stream handler never returns
    # naturally, so don't make Ctrl+C wait for the default 5s timeout.
    uvicorn.run(
        app,
        host="0.0.0.0",
        port=config.port,
        log_level="warning",
        timeout_graceful_shutdown=2,
    )
    return 0


def _install_cli_sigint_handler() -> None:
    """First Ctrl+C: set cancel flag and message. Second: force exit.

    Python defers KeyboardInterrupt during blocking C-level reads (e.g. the
    anthropic streaming socket), so a single Ctrl+C can appear to hang. The
    second SIGINT short-circuits with os._exit so the user always has an
    escape hatch.
    """
    armed = [False]

    def handler(signum: int, frame: Any) -> None:
        if armed[0]:
            print("\nforcing exit", file=sys.stderr)
            os._exit(130)
        armed[0] = True
        _CANCEL_EVENT.set()
        print(
            "\ncaught Ctrl+C, finishing current step "
            "(press again to force quit)",
            file=sys.stderr,
        )

    signal.signal(signal.SIGINT, handler)


def main() -> int:
    args = _build_parser().parse_args()
    config = Config.from_args(args)
    history = History(config.cache_dir)

    if config.dry_run:
        print(f"config: {config}")
        print(f"baseline_sha: {history.baseline_sha}")
        print(f"attempts: {len(history.attempts)}")
        return 0

    if config.serve:
        # uvicorn installs its own SIGINT handler — don't fight it.
        return serve(config)

    _install_cli_sigint_handler()
    try:
        return run(config, history)
    except KeyboardInterrupt:
        print("\ninterrupted", file=sys.stderr)
        return 130


if __name__ == "__main__":
    sys.exit(main())
