class GitSource(Source):
    def __init__(self, url: str, local_src_dir: pathlib.Path):
        self._url = url
        self._local = local_src_dir

    def prepare(self):
        self._repo = git.Repo.clone_from(self._url, self._local)
        print(f"cloning in {self._local}")


class FilesystemSource(Source):
    def __init__(self, path: str, local_src_dir: pathlib.Path):
        self._path = pathlib.Path(path)
        self._local = local_src_dir

    def prepare(self, commit_wip: bool = False):
        shutil.copytree(self._path, self._local, dirs_exist_ok=True)
        self._repo = git.Repo(self._local)

        if self._repo.is_dirty(untracked_files=True):
            if commit_wip:
                d.log("Committing local changes in source directory")
                self._repo.git.add(A=True)
                self._repo.index.commit("<wip>")
            else:
                d.log("Wiping local changes in source directory")
                self._repo.git.reset("--hard", 'HEAD')
                self._repo.git.clean("-fd")


def getSource(src, local_src_dir) -> Source | None:
    if src.startswith("https://"):
        return GitSource(src, local_src_dir)
    else:
        return FilesystemSource(src, local_src_dir)


import io


def get_rsa_key(key_path: pathlib.Path) -> paramiko.RSAKey:
    with open(key_path, "rb") as key:
        data = key.read()

    pkey = serialization.load_pem_private_key(data, None)
    pkcs1 = pkey.private_bytes(
        encoding=serialization.Encoding.PEM,
        format=serialization.PrivateFormat.TraditionalOpenSSL,
        encryption_algorithm=serialization.NoEncryption(),
    )

    return paramiko.RSAKey.from_private_key(io.StringIO(pkcs1.decode("utf-8")))


import uuid


class Executor:
    def __init__(self, args):
        self._host: str = args.host
        self._workdir = (
            pathlib.Path(tempfile.gettempdir()) / f"bpfilter-{uuid.uuid4().hex[:8]}"
        )
        self._local_workdir = self._workdir
        self._cache_path = pathlib.Path(args.cache_dir)
        self._log_file = args.log_file
        self._log_fh = None

    def __enter__(self):
        self._cache = diskcache.Cache(self._cache_path)
        self._local_workdir.mkdir()
        if self._log_file:
            self._log_fh = open(self._log_file, "a")

        if self._host != DEFAULT_HOST:
            self._remote_workdir = self._workdir

            self._client = paramiko.SSHClient()
            self._client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
            self._client.connect(
                self._host,
                username="quentin",
                pkey=get_rsa_key(
                    pathlib.Path(f"/home/quentin/.ssh/quentin@{self._host}")
                ),
            )

            self.run(f"mkdir -p {self._remote_workdir}")
            self.run(
                f"sshfs quentin@bf-dev:{self._local_workdir} {self._remote_workdir} -C -o allow_other,default_permissions,exec,user,identityfile=/home/quentin/.ssh/id_ed25519"
            )

        return self

    def __exit__(self, exc_type, exc_value, tracebook):
        self._cache.close()

        if self._host != DEFAULT_HOST:
            self.run(f"fusermount3 -u {self._remote_workdir}")
            self.run(f"rm -rf {self._remote_workdir}")

        if self._log_fh:
            self._log_fh.close()

        shutil.rmtree(self._local_workdir)

    @property
    def host(self) -> str:
        return self._host

    @property
    def srcdir(self) -> pathlib.Path:
        return self._local_workdir / "bpfilter"

    @property
    def cache(self) -> diskcache.Cache:
        return self._cache

    def get_builddir(self, commit) -> pathlib.Path:
        return self._local_workdir / commit.hexsha

    def _log(self, msg: str):
        d.log(msg)
        if self._log_fh:
            self._log_fh.write(msg + "\n")
            self._log_fh.flush()

    def run(self, cmd: str, timeout: int = None) -> int:
        cmd = cmd.replace("{WORKDIR}", str(self._workdir))

        if self._host == DEFAULT_HOST:
            p = subprocess.Popen(
                split(cmd),
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
            )

            start_time = time.time()

            while True:
                if timeout and (time.time() - start_time) > timeout:
                    p.kill()
                    p.wait()
                    self._log("[red]⏰ Command timed out[/red]")
                    return errno.ETIMEDOUT

                ready, _, _ = select.select([p.stdout], [], [], 0.1)
                if ready:
                    line = p.stdout.readline()
                    if not line:
                        break
                    line = line.rstrip()
                    if line:
                        self._log(line)
                elif p.poll() is not None:
                    break

            p.wait()
            return p.returncode if p.returncode is not None else 1
        else:
            _, stdout, _ = self._client.exec_command(cmd)

            # Use select to read from both stdout and stderr as data arrives
            while not stdout.channel.exit_status_ready():
                if stdout.channel.recv_ready():
                    data = stdout.channel.recv(1024).decode('utf-8')
                    for line in data.splitlines():
                        if line:
                            self._log(line)

                if stdout.channel.recv_stderr_ready():
                    data = stdout.channel.recv_stderr(1024).decode('utf-8')
                    for line in data.splitlines():
                        if line:
                            self._log(line)

            # Read any remaining data after command completes
            while stdout.channel.recv_ready():
                data = stdout.channel.recv(1024).decode('utf-8')
                for line in data.splitlines():
                    if line:
                        self._log(line)

            while stdout.channel.recv_stderr_ready():
                data = stdout.channel.recv_stderr(1024).decode('utf-8')
                for line in data.splitlines():
                    if line:
                        self._log(line)

            return stdout.channel.exit_status


def show_commit_status(status: str, short_sha: str, details: str = None):
    """Display commit status with Rich panels"""
    if status == "cached":
        panel = Panel(
            "✅ Restored from cache",
            title=f"[bold green]{short_sha}[/bold green]",
            border_style="green",
        )
    elif status == "buggy_cached":
        panel = Panel(
            "⚠️  Found in cache, marked as buggy",
            title=f"[bold yellow]{short_sha}[/bold yellow]",
            border_style="yellow",
        )
    elif status == "buggy_new":
        panel = Panel(
            "❌ Build/benchmark failed",
            title=f"[bold red]{short_sha}[/bold red]",
            border_style="red",
        )
    elif status == "generated":
        panel = Panel(
            "🎯 Benchmark completed successfully",
            title=f"[bold green]{short_sha}[/bold green]",
            border_style="green",
        )
    else:
        panel = Panel(
            details or "Unknown status",
            title=f"[bold]{short_sha}[/bold]",
            border_style="white",
        )

    console.print(panel)


