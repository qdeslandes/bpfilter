def get_class(stats) -> str:
    if not stats._significant:
        return "neutral"

    if stats._pct_change > 0:
        return "is-significant text-danger"
    else:
        return "is-significant text-success"



def run_benchmark(build_dir: pathlib.Path, label: str = "current", log_file: str = None) -> dict | None:
    """Run benchmark in a given build directory. Returns benchmark results or None on failure."""
    benchmark_result_path = build_dir / "benchmarks" / f"{label}.json"

    # Open log file if specified
    log_fh = open(log_file, "a") if log_file else None

    def log(msg: str):
        console.print(f"  {msg}")
        if log_fh:
            log_fh.write(msg + "\n")
            log_fh.flush()

    # Run make benchmark
    console.print(f"[blue]🔨 Running benchmark in {build_dir}...[/blue]")
    p = subprocess.Popen(
        ["make", "-C", str(build_dir), "-j", str(multiprocessing.cpu_count()), "benchmark"],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
    )

    start_time = time.time()
    timeout = 60

    while True:
        if (time.time() - start_time) > timeout:
            p.kill()
            p.wait()
            console.print("[red]⏰ Benchmark timed out after 60s[/red]")
            if log_fh:
                log_fh.close()
            return errno.ETIMEDOUT

        ready, _, _ = select.select([p.stdout], [], [], 0.1)
        if ready:
            line = p.stdout.readline()
            if not line:
                break
            line = line.rstrip()
            if line:
                log(line)
        elif p.poll() is not None:
            break

    if log_fh:
        log_fh.close()

    p.wait()
    if p.returncode:
        console.print("[red]❌ Benchmark failed[/red]")
        return None

    if not benchmark_result_path.exists():
        console.print(f"[red]❌ Benchmark results not found at {benchmark_result_path}[/red]")
        return None

    with open(benchmark_result_path, "r") as f:
        return json.load(f)["benchmarks"]


def cmd_run(args):
    """Run benchmark once on current sources (no git, no source copy)."""
    build_dir = pathlib.Path(args.build_dir).resolve()
    source_dir = pathlib.Path(args.source_dir).resolve()

    if not build_dir.exists():
        console.print(f"[red]❌ Build directory does not exist: {build_dir}[/red]")
        console.print("[yellow]Hint: Run cmake to configure the build first[/yellow]")
        sys.exit(1)

    console.print(Panel(
        f"Source: {source_dir}\nBuild: {build_dir}",
        title="🚀 bfbencher run",
        border_style="blue"
    ))

    start_time = time.time()

    # Get commit info if in a git repo
    commit_sha = "unknown"
    commit_subject = "Local build"
    try:
        repo = git.Repo(source_dir)
        commit_sha = repo.head.commit.hexsha
        commit_subject = repo.head.commit.summary
        if repo.is_dirty():
            commit_subject += " (dirty)"
        console.print(f"[dim]Commit: {commit_sha[:7]} - {commit_subject}[/dim]")
    except git.InvalidGitRepositoryError:
        console.print("[dim]Not a git repository, using 'unknown' as commit[/dim]")

    # Run the benchmark
    benchmark_results = run_benchmark(build_dir, commit_sha[:7] if commit_sha != "unknown" else "local", args.log_file)

    if benchmark_results is None:
        sys.exit(1)

    total_time = time.time() - start_time

    # Create results
    results = History(1)
    results.add_results(commit_sha, benchmark_results, commit_subject)

    # Output results
    if args.output == "json":
        output = {
            "commit": commit_sha,
            "subject": commit_subject,
            "benchmarks": benchmark_results
        }
        print(json.dumps(output, indent=2))
    elif args.output == "html":
        script_dir = pathlib.Path(__file__).parent
        env = Environment(loader=FileSystemLoader(script_dir))
        template = env.get_template("results.html.j2")

        output_path = pathlib.Path(args.output_file)
        with open(output_path, "w") as f:
            f.write(
                template.render(
                    history=results,
                    hostname="localhost",
                    first_commit_sha=commit_sha,
                    last_commit_sha=commit_sha,
                    n_commits=1,
                    n_results=1,
                    terms=[],
                    ureg=ureg,
                    get_class=get_class,
                )
            )
        console.print(Panel(
            f"✅ Report generated: [bold green]{output_path}[/bold green]",
            title="🎉 Complete",
            border_style="green"
        ))
    else:  # console output
        table = Table(title="Benchmark Results")
        table.add_column("Benchmark", style="cyan")
        table.add_column("Runtime", justify="right", style="green")
        table.add_column("Instructions", justify="right", style="yellow")

        for bench in results.benchmarks:
            insn = str(int(bench.last.nInsn)) if bench.last.nInsn else "—"
            table.add_row(bench.label or bench.name, f"{bench.last.time:.2f~}", insn)

        console.print(table)
        console.print(f"\n[dim]Completed in {total_time:.1f}s[/dim]")


def cmd_history(args):
    """Run historical benchmarks across git commits."""

    d.log("[blue]🚀 Starting bfbencher history...[/blue]")

    with Live(d._layout, console=d._console, refresh_per_second=10):
        with Executor(args) as e:
            d.log(f"[blue]🔧 Preparing source from {args.sources}...[/blue]")
            source = getSource(args.sources, e.srcdir)
            source.prepare(commit_wip = args.until is None)

            if args.until is None:
                args.until = 'HEAD'


            d.log(f"[blue]📦 Fetching commits from {args.since} to {args.until}...[/blue]")
            commits = list(
                source.repo.iter_commits(f"{args.since}^..{args.until}", reverse=True)
            )

            d.first_commit = commits[0]
            d.last_commit = commits[-1]
            d.n_commits = len(commits)

            results = History(len(commits))

            for commit in commits:
                d.log(f"[blue]🔨 Processing commit {commit.hexsha}...[/blue]")
                d.current_commit = commit

                short_sha = source.repo.git.rev_parse(commit, short=7)

                cache_key = f"{commit.hexsha}-{args.host}"
                cached_data = e.cache.get(cache_key, None)

                if cached_data:
                    d.cache_hit()
                    if "results" not in cached_data:
                        d.results_failure()
                    else:
                        results.add_results(commit.hexsha, cached_data["results"], commit.summary)
                        d.results_success()
                    d.update_progress()
                    continue

                # No cached data, checkout and run the benchmark
                d.cache_miss()
                source.repo.git.checkout(commit)

                new_data = {
                    "summary": commit.summary,
                    "commit_date": commit.committed_datetime,
                }

                builddir = e.get_builddir(commit)
                benchmark_result_path = (
                    builddir / "benchmarks" / f"{short_sha}.json"
                )

                # Cleanup the system
                d.log("[blue]🧼 Cleaning up system before building...[/blue]")
                e.run("sudo rm -rf /run/bpfilter")
                e.run("sudo rm -rf /sys/fs/bpf/bpfilter")
                e.run("sudo killall bpfilter")

                d.log(f"[blue]⚙️  Building commit {commit.hexsha}...[/blue]")
                r = e.run(
                    f"cmake -S {{WORKDIR}}/bpfilter -B {{WORKDIR}}/{commit.hexsha}"
                )
                if r:
                    d.results_failure()
                    e.cache[cache_key] = new_data
                    d.update_progress()
                    continue

                r = e.run(
                    f"make -C {{WORKDIR}}/{commit.hexsha} -j {multiprocessing.cpu_count()} benchmark",
                    timeout=60
                )
                if r:
                    d.results_failure()
                    e.cache[cache_key] = new_data
                    d.update_progress()
                    continue

                with open(benchmark_result_path, "r") as results_file:
                    new_data["results"] = json.load(results_file)["benchmarks"]
                    e.cache[cache_key] = new_data
                    results.add_results(commit.hexsha, new_data["results"], commit.summary)

                d.results_success()
                d.update_progress()

            # Generate HTML report with a nice message
            script_dir = pathlib.Path(__file__).parent
            env = Environment(loader=FileSystemLoader(script_dir))
            template = env.get_template("results.html.j2")

            with open(args.output_file, "w") as f:
                f.write(
                    template.render(
                        history=results,
                        hostname=e.host,
                        first_commit_sha=commits[0].hexsha,
                        last_commit_sha=commits[-1].hexsha,
                        n_commits=len(commits),
                        n_results=len(commits) - d._stats.results_failure,
                        terms=[5, 15],
                        ureg=ureg,
                        get_class=get_class,
                    )
                )


def main():
    parser = argparse.ArgumentParser(
        prog="bfbencher",
        description="Run and analyze bpfilter's performance",
    )
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # 'run' subcommand - one-off benchmark on current sources
    run_parser = subparsers.add_parser(
        "run",
        help="Run benchmark once on current sources (no git operations)",
    )
    run_parser.add_argument(
        "--build-dir", "-b",
        type=str,
        help="Path to the build directory. Defaults to './build'.",
        default="./build",
    )
    run_parser.add_argument(
        "--source-dir", "-s",
        type=str,
        help="Path to the source directory. Defaults to current directory.",
        default=".",
    )
    run_parser.add_argument(
        "--output", "-o",
        type=str,
        choices=["console", "json", "html"],
        help="Output format. Defaults to 'console'.",
        default="console",
    )
    run_parser.add_argument(
        "--output-file",
        type=str,
        help="Output file path for HTML output. Defaults to 'results.html'.",
        default="results.html",
    )
    run_parser.add_argument(
        "--log-file",
        type=str,
        help="Path to write build/benchmark logs.",
        default=None,
    )
    run_parser.set_defaults(func=cmd_run)

    # 'history' subcommand - historical benchmark across commits
    history_parser = subparsers.add_parser(
        "history",
        help="Run historical benchmarks across git commits",
    )
    history_parser.add_argument(
        "--since",
        type=str,
        help=f"First commit to test. Defaults to '{FIRST_COMMIT}'",
        default=FIRST_COMMIT,
    )
    history_parser.add_argument(
        "--until",
        type=str,
        help=f"Last commit to test. Defaults to '{LAST_COMMIT}'.",
        default=LAST_COMMIT,
    )
    history_parser.add_argument(
        "--sources",
        type=str,
        help=f"bpfilter sources location. Defaults to '{BPFILTER_REPO_URL}'.",
        default=BPFILTER_REPO_URL,
    )
    history_parser.add_argument(
        "--host",
        type=str,
        help=f"Host to run the benchmark on. Defaults to {DEFAULT_HOST}.",
        default=DEFAULT_HOST,
    )
    history_parser.add_argument(
        "--cache-dir",
        type=str,
        help=f"Path of the cache directory. Defaults to {DEFAULT_CACHE_PATH}.",
        default=DEFAULT_CACHE_PATH,
    )
    history_parser.add_argument(
        "--log-file",
        type=str,
        help="Path to write build/benchmark logs.",
        default=None,
    )
    history_parser.add_argument(
        "--output-file",
        type=str,
        help="Output file path for HTML report. Defaults to 'results.html'.",
        default="results.html",
    )
    history_parser.set_defaults(func=cmd_history)

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    args.func(args)


if __name__ == "__main__":
    main()