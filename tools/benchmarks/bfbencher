class Result:
    def __init__(self, index: int, commit_sha: str, raw: dict, commit_subject: str = ""):
        self._index = index
        self._commit = commit_sha
        self._commit_subject = commit_subject
        self._name = raw["name"]
        self._iterations = raw["iterations"]
        self._real_time = raw["real_time"] * ureg(raw["time_unit"])
        self._cpu_time = raw["cpu_time"] * ureg(raw["time_unit"])
        self._label = raw.get("label", "")

        # Some benchmark don't store the number of instructions
        self._nInsn = raw.get("nInsn", None)

    @property
    def index(self) -> int:
        return self._index

    @property
    def commit_sha(self) -> str:
        return self._commit

    @property
    def short_commit_sha(self) -> str:
        return self._commit[:7]

    @property
    def commit_subject(self) -> str:
        return self._commit_subject

    @property
    def name(self) -> str:
        return self._name

    @property
    def time(self):
        return self._cpu_time.to_compact()

    @property
    def nInsn(self):
        return self._nInsn

    @property
    def label(self):
        return self._label

    def toJSON(self) -> dict:
        return dict(
            index=self._index,
            commit=self._commit,
            name=self._name,
            iterations=self._iterations,
            real_time=str(self._real_time),
            cpu_time=str(self._cpu_time),
            nInsn=self._nInsn,
        )


class Analyzer:
    def __init__(self, last_result: int, results: list[int], threshold: float = 1.0):
        self._mean = numpy.mean(results)
        self._std = numpy.std(results)
        self._std_pct = (self._std / self._mean) * 100 if self._std else 0
        self._z_score = (last_result - self._mean) / self._std if self._std else 0
        self._noise = self._std / self._mean
        self._pct_change = ((last_result - self._mean) / self._mean) * 100
        self._significant = abs(self._z_score) > threshold

    def toJSON(self) -> dict:
        return dict(
            mean=self._mean,
            std=self._std,
            z_score=self._z_score,
            noise=self._noise,
            pct_change=self._pct_change,
            significant=(1 if self._significant else 0),
        )

    @property
    def mean(self):
        return self._mean


class Benchmark:
    def __init__(self, name: str):
        self._name = name
        self._results: list[Result] = []
        self._stats: dict[str, Analyzer | None] = {
            "time": None,
            "nInsn": None,
        }
        self._label = ""

    def add_result(self, result: Result) -> None:
        self._results.append(result)
        self._label = result.label

    @property
    def name(self) -> str:
        return self._name

    @property
    def timeStats(self) -> Analyzer:
        return self._stats["time"]

    @property
    def nInsnStats(self) -> Analyzer:
        return self._stats["nInsn"]

    @property
    def label(self) -> str:
        return self._label

    def get_stats(self, n: int):
        if len(self._results) < n + 1:
            return None

        times = [x.time.to("nanoseconds").magnitude for x in self._results]
        nInsns = self.nInsns

        return {
            "time": Analyzer(times[-1], times[-n - 1 : -1], 2.0),
            "nInsn": Analyzer(nInsns[-1], nInsns[-n - 1 : -1], 2.0) if nInsns else None,
        }

    @property
    def last(self) -> Result | None:
        return self._results[-1] if self._results else None

    @property
    def times(self) -> list[int]:
        return [x.time.to(ureg.ns).magnitude for x in self._results]

    @property
    def nInsns(self) -> list[int] | None:
        nInsns = [x.nInsn for x in self._results]
        if None not in nInsns:
            return nInsns
        return None

    @property
    def commits_sha(self) -> list[str]:
        return [x.commit_sha for x in self._results]

    @property
    def short_commits_sha(self) -> list[str]:
        return [x.short_commit_sha for x in self._results]

    @property
    def commit_subjects(self) -> list[str]:
        return [x.commit_subject for x in self._results]

    def toJSON(self) -> dict:
        return dict(name=self._name, results=self._results, stats=self._stats)


class History:
    def __init__(self, n_commits: int):
        self._n_commits = n_commits
        self._results = []

    def add_result(self, idx: int, commit_sha: str, result: dict, commit_subject: str = "") -> None:
        result = Result(idx, commit_sha, result, commit_subject)

        bench = next((x for x in self._results if x.name == result.name), None)
        if not bench:
            bench = Benchmark(result.name)
            self._results.append(bench)
            self._results.sort(key=lambda x: x.name)

        bench.add_result(result)

    def add_results(self, commit_sha: str, results: list, commit_subject: str = "") -> None:
        for r in results:
            self.add_result(0, commit_sha, r, commit_subject)

        # Sort benchmark in to the current results order
        data = []
        order = [x["name"] for x in results]
        for name in order:
            b = self.get_benchmark(name)
            if b:
                data.append(b)
            else:
                print(f"warning: benchmark {name} not found")
        self._results = data

    @property
    def benchmarks(self):
        return self._results

    def get_benchmark(self, name: str) -> Benchmark | None:
        return next((x for x in self._results if x.name == name), None)

    def toJSON(self) -> dict:
        return dict(n_commits=self._n_commits, results=self._results)


